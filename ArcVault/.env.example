# ──────────────────────────────────────────────
# Database (Railway PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/arcvault?schema=public"

# ──────────────────────────────────────────────
# Arc Blockchain
# ──────────────────────────────────────────────
ARC_RPC_URL="https://rpc.arc-testnet.example.com"
NEXT_PUBLIC_CHAIN_ID="1397"
NEXT_PUBLIC_ARC_RPC_URL="https://testnet-rpc.arc.io"
NEXT_PUBLIC_ARC_EXPLORER_URL="https://testnet-explorer.arc.io"

# ──────────────────────────────────────────────
# Deployed Contract Addresses (populated after deploy)
# ──────────────────────────────────────────────
NEXT_PUBLIC_TREASURY_VAULT_ADDRESS="0x0000000000000000000000000000000000000001"
NEXT_PUBLIC_PAYOUT_ROUTER_ADDRESS="0x0000000000000000000000000000000000000002"
NEXT_PUBLIC_BUDGET_MANAGER_ADDRESS="0x0000000000000000000000000000000000000003"
NEXT_PUBLIC_USDC_ADDRESS="0x0000000000000000000000000000000000000004"

# ──────────────────────────────────────────────
# CPN (Cross-border Payment Network) Integration
# ──────────────────────────────────────────────
CPN_API_KEY="your_circle_api_key"
CPN_API_URL="https://api-sandbox.circle.com"
CPN_WALLET_ID=""

# ──────────────────────────────────────────────
# StableFX Integration
# ──────────────────────────────────────────────
STABLEFX_API_KEY="your_circle_api_key"
STABLEFX_API_URL="https://api-sandbox.circle.com"

# ──────────────────────────────────────────────
# Cron Secret (Vercel Cron authorization)
# ──────────────────────────────────────────────
CRON_SECRET=""

# ──────────────────────────────────────────────
# WalletConnect
# ──────────────────────────────────────────────
